.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 48rpx;
  background: linear-gradient(180deg, #F0F5FF 0%, #F6F7FB 100%);
  box-sizing: border-box;
}

.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(30, 111, 255, 0.08);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.cardTitle {
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 20rpx;
  padding-left: 4rpx;
}

.row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.label {
  width: 140rpx;
  font-size: 28rpx;
  color: #4B5563;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.seg {
  flex: 1;
  display: flex;
  background: #F3F4F6;
  border-radius: 16rpx;
  padding: 6rpx;
}

.segItem {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #6B7280;
  transition: all 0.2s ease;
}

.segItem.on {
  background: #FFFFFF;
  color: #1E6FFF;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(30, 111, 255, 0.15);
}

.colorRow {
  flex: 1;
  display: flex;
  gap: 16rpx;
}

.colorItem {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  border: 2rpx solid #E5E7EB;
  transition: all 0.2s ease;
}

.colorItem.on {
  border: 3rpx solid #1E6FFF !important;
  box-shadow: 0 0 0 6rpx rgba(30, 111, 255, 0.15);
  transform: scale(1.05);
}

.primaryBtn {
  background: linear-gradient(135deg, #1E6FFF 0%, #3B82F6 100%);
  color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  width: 100%;
  box-shadow: 0 8rpx 24rpx rgba(30, 111, 255, 0.25);
}

.primaryBtn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(30, 111, 255, 0.2);
}

.ghostBtn {
  background: #FFFFFF;
  color: #1E6FFF;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: 2rpx solid #E5E7EB;
  width: 100%;
}

.ghostBtn:active {
  background: #F9FAFB;
}

.previewGrid {
  display: flex;
  margin: 0 -8rpx;
}

.previewItem {
  width: 50%;
  box-sizing: border-box;
  padding: 0 8rpx;
  display: flex;
  flex-direction: column;
}

.previewLabel {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.previewImg {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  background: #F3F4F6;
  border: 2rpx solid #E5E7EB;
}

.previewMeta {
  font-size: 26rpx;
  color: #374151;
  margin-top: 12rpx;
  text-align: center;
}

.actions {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.actions button {
  flex: 1;
}

.hiddenCanvas {
  position: fixed;
  left: -2000rpx;
  top: -2000rpx;
  width: 1000px;
  height: 1000px;
}

.imagePreview {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #EFF6FF 0%, #F8FAFC 100%);
  border-radius: 16rpx;
  padding: 16rpx;
  border: 2rpx solid #BFDBFE;
}

.previewImage {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #E5E7EB;
  flex-shrink: 0;
}

.imageInfo {
  flex: 1;
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
}

.infoText {
  font-size: 28rpx;
  color: #1F2937;
  font-weight: 600;
}

.infoSize {
  font-size: 24rpx;
  color: #6B7280;
  margin-top: 6rpx;
}

.changeBtn {
  padding: 12rpx 24rpx;
  background: #FFFFFF;
  border: 2rpx solid #E5E7EB;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #1E6FFF;
  font-weight: 500;
}

.apiWarning {
  display: flex;
  align-items: flex-start;
  background: linear-gradient(135deg, #FEF3C7 0%, #FFFBEB 100%);
  border: 2rpx solid #FCD34D;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.warningIcon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.warningText {
  font-size: 26rpx;
  color: #92400E;
  line-height: 1.5;
}