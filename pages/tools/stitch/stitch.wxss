/* 图片列表 */
.imageList {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.imageItem {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  position: relative;
  overflow: hidden;
  background: #F3F4F6;
  border: 2rpx solid #E5E7EB;
}

.imageThumb {
  width: 100%;
  height: 100%;
}

.imageRemove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 300;
}

.imageIndex {
  position: absolute;
  bottom: 4rpx;
  left: 4rpx;
  padding: 4rpx 12rpx;
  background: rgba(30, 111, 255, 0.9);
  color: #FFFFFF;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.addBtn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #D1D5DB;
  background: #F9FAFB;
}

.addIcon {
  font-size: 48rpx;
  color: #9CA3AF;
  line-height: 1;
}

.addText {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
}

.smallInput {
  width: 120rpx;
  text-align: center;
  padding: 16rpx;
}

/* 结果预览 */
.resultPreview {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.resultImage {
  width: 100%;
  border-radius: 16rpx;
  background: #F3F4F6;
}

.resultMeta {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #6B7280;
}