page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  -webkit-font-smoothing: antialiased;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 48rpx;
  background: linear-gradient(180deg, #F0F5FF 0%, #F6F7FB 100%);
  box-sizing: border-box;
}

.header {
  padding: 16rpx 8rpx 24rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1F2937;
}

.subtitle {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #6B7280;
}

.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(30, 111, 255, 0.08);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.cardTitle {
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 20rpx;
  padding-left: 4rpx;
}

.row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.label {
  width: 140rpx;
  font-size: 28rpx;
  color: #4B5563;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.seg {
  display: flex;
  background: #F3F4F6;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 20rpx;
}

.row .seg {
  flex: 1;
  margin-bottom: 0;
}

.segItem {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #6B7280;
  transition: all 0.2s ease;
}

.segItem.on {
  background: #FFFFFF;
  color: #1E6FFF;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(30, 111, 255, 0.15);
}

.input {
  flex: 1;
  background: #F9FAFB;
  border: 2rpx solid #E5E7EB;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #111827;
}

.input:focus {
  border-color: #1E6FFF;
  background: #FFFFFF;
}

.primaryBtn {
  background: linear-gradient(135deg, #1E6FFF 0%, #3B82F6 100%);
  color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  width: 100%;
  box-shadow: 0 8rpx 24rpx rgba(30, 111, 255, 0.25);
}

.primaryBtn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(30, 111, 255, 0.2);
}

.ghostBtn {
  background: #FFFFFF;
  color: #1E6FFF;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: 2rpx solid #E5E7EB;
  width: 100%;
}

.ghostBtn:active {
  background: #F9FAFB;
}

.pillBtn {
  background: rgba(30, 111, 255, 0.10);
  color: #1E6FFF;
  border-radius: 999rpx;
  font-size: 26rpx;
  padding: 14rpx 24rpx;
  font-weight: 500;
}

.colorRow {
  flex: 1;
  display: flex;
  gap: 16rpx;
}

.colorItem {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  border: 2rpx solid #E5E7EB;
  transition: all 0.2s ease;
}

.colorItem.on {
  border: 3rpx solid #1E6FFF !important;
  box-shadow: 0 0 0 6rpx rgba(30, 111, 255, 0.15);
  transform: scale(1.05);
}

.previewGrid {
  display: flex;
  margin: 0 -8rpx;
}

.previewItem {
  width: 50%;
  box-sizing: border-box;
  padding: 0 8rpx;
  display: flex;
  flex-direction: column;
}

.previewLabel {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.previewImg {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  background: #F3F4F6;
  border: 2rpx solid #E5E7EB;
}

.previewMeta {
  font-size: 26rpx;
  color: #374151;
  margin-top: 12rpx;
  text-align: center;
}

.actions {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.actions button {
  flex: 1;
}

.dragNumWrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
}

.dragNumInner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 60rpx;
  background: linear-gradient(135deg, #EFF6FF 0%, #DBEAFE 100%);
  border-radius: 20rpx;
  border: 2rpx solid #BFDBFE;
  min-width: 200rpx;
}

.dragNumValue {
  font-size: 56rpx;
  font-weight: 700;
  color: #1E6FFF;
  line-height: 1.2;
}

.dragNumHint {
  font-size: 22rpx;
  color: #60A5FA;
  margin-top: 8rpx;
  font-weight: 500;
}

.hiddenCanvas {
  position: fixed;
  left: -2000rpx;
  top: -2000rpx;
  width: 1000px;
  height: 1000px;
}

.tipsCard {
  margin-top: 20rpx;
  background: linear-gradient(135deg, rgba(30, 111, 255, 0.08) 0%, rgba(99, 102, 241, 0.06) 100%);
  border: 2rpx solid rgba(30, 111, 255, 0.15);
  border-radius: 20rpx;
  padding: 24rpx;
}

.tipsTitle {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2937;
}

.tipsLine {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
}

.empty {
  margin-top: 160rpx;
  text-align: center;
}

.emptyTitle {
  font-size: 36rpx;
  font-weight: 700;
  color: #1F2937;
}

.emptySub {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #6B7280;
}

.textBtn {
  background: transparent;
  color: #1E6FFF;
  font-size: 28rpx;
  padding: 12rpx 16rpx;
  font-weight: 500;
}
