<view class="page">
  <view class="card">
    <view class="cardTitle">选择图片</view>
    <view class="imagePreview" wx:if="{{inputPath}}">
      <image class="previewImage" src="{{inputPath}}" mode="aspectFill" bindtap="preview" data-url="{{inputPath}}" />
      <view class="imageInfo">
        <text class="infoText">已选择图片</text>
        <text class="infoSize" wx:if="{{inputSizeKB}}">{{inputSizeKB}}KB</text>
      </view>
      <view class="changeBtn" bindtap="choose">更换</view>
    </view>
    <button class="primaryBtn" wx:else bindtap="choose">从相册/相机选择</button>
  </view>

  <view class="card" wx:if="{{inputPath}}">
    <view class="cardTitle">编辑参数</view>

    <view class="row">
      <text class="label">输出宽度</text>
      <input class="input" type="number" value="{{outW}}" placeholder="例如 1080" bindinput="onOutW" />
    </view>

    <view class="row">
      <text class="label">输出高度</text>
      <input class="input" type="number" value="{{outH}}" placeholder="例如 1920" bindinput="onOutH" />
    </view>

    <view class="row">
      <text class="label">适配模式</text>
      <view class="seg">
        <view class="segItem {{fit === 'contain' ? 'on' : ''}}" bindtap="onFitChange" data-fit="contain">适应</view>
        <view class="segItem {{fit === 'cover' ? 'on' : ''}}" bindtap="onFitChange" data-fit="cover">裁剪</view>
      </view>
    </view>

    <view class="row">
      <text class="label">输出格式</text>
      <view class="seg">
        <view class="segItem {{fileType === 'jpg' ? 'on' : ''}}" bindtap="onFileTypeChange" data-type="jpg">JPG</view>
        <view class="segItem {{fileType === 'png' ? 'on' : ''}}" bindtap="onFileTypeChange" data-type="png">PNG</view>
        <view class="segItem {{fileType === 'webp' ? 'on' : ''}}" bindtap="onFileTypeChange" data-type="webp">WebP
        </view>
      </view>
    </view>

    <view class="row">
      <text class="label">质量</text>
      <view class="dragNumWrap">
        <view class="dragNumInner" bindtouchstart="onQualityTouchStart" bindtouchmove="onQualityTouchMove"
          bindtouchend="onQualityTouchEnd">
          <text class="dragNumValue">{{quality}}</text>
          <text class="dragNumHint">← 滑动调整 →</text>
        </view>
      </view>
    </view>

    <view class="row">
      <button class="primaryBtn" disabled="{{busy}}" bindtap="run">开始编辑</button>
    </view>
  </view>

  <view class="card" wx:if="{{result}}">
    <view class="cardTitle">结果预览</view>
    <view class="previewGrid">
      <view class="previewItem">
        <text class="previewLabel">原图</text>
        <image class="previewImg" src="{{result.inputPath}}" mode="aspectFill" bindtap="preview"
          data-url="{{result.inputPath}}" />
        <text class="previewMeta">{{result.inputSizeKB}}KB</text>
      </view>
      <view class="previewItem">
        <text class="previewLabel">编辑后</text>
        <image class="previewImg" src="{{result.outputPath}}" mode="aspectFill" bindtap="preview"
          data-url="{{result.outputPath}}" />
        <text class="previewMeta">{{result.outputSizeKB}}KB</text>
      </view>
    </view>

    <view class="actions">
      <button class="primaryBtn" bindtap="save">保存到相册</button>
      <button class="ghostBtn" bindtap="share">分享</button>
    </view>
  </view>

  <canvas type="2d" id="toolCanvas" class="hiddenCanvas"></canvas>
</view>