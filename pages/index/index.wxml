<view class="page">
  <view class="header">
    <view class="headerIcon">🛠️</view>
    <view class="headerContent">
      <view class="title">图像工具箱</view>
      <view class="subtitle">一站式图片处理解决方案</view>
    </view>
  </view>

  <view class="section">
    <view class="sectionTitle">基础工具</view>
    <view class="tool-grid">
      <view class="tool-card" bindtap="navigateToTool" data-tool="compress">
        <view class="tool-icon">
          <text class="icon">🗜️</text>
        </view>
        <view class="tool-name">图片压缩</view>
        <view class="tool-desc">调整大小和质量</view>
      </view>

      <view class="tool-card" bindtap="navigateToTool" data-tool="edit">
        <view class="tool-icon">
          <text class="icon">📏</text>
        </view>
        <view class="tool-name">图片编辑</view>
        <view class="tool-desc">调整尺寸和格式</view>
      </view>

      <view class="tool-card" bindtap="navigateToTool" data-tool="crop">
        <view class="tool-icon">
          <text class="icon">✂️</text>
        </view>
        <view class="tool-name">图片裁剪</view>
        <view class="tool-desc">自由裁剪图片</view>
      </view>

      <view class="tool-card" bindtap="navigateToTool" data-tool="rotate">
        <view class="tool-icon">
          <text class="icon">🔄</text>
        </view>
        <view class="tool-name">图片旋转</view>
        <view class="tool-desc">旋转和翻转图片</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="sectionTitle">美化工具</view>
    <view class="tool-grid">
      <view class="tool-card" bindtap="navigateToTool" data-tool="adjust">
        <view class="tool-icon">
          <text class="icon">🎨</text>
        </view>
        <view class="tool-name">图片调色</view>
        <view class="tool-desc">亮度对比度饱和度</view>
      </view>

      <view class="tool-card" bindtap="navigateToTool" data-tool="watermark">
        <view class="tool-icon">
          <text class="icon">✏️</text>
        </view>
        <view class="tool-name">添加水印</view>
        <view class="tool-desc">文字或图片水印</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="sectionTitle">特色工具</view>
    <view class="tool-grid">
      <view class="tool-card" bindtap="navigateToTool" data-tool="idphoto">
        <view class="tool-icon">
          <text class="icon">🪪</text>
        </view>
        <view class="tool-name">证件照</view>
        <view class="tool-desc">一寸/二寸证件照</view>
      </view>

      <view class="tool-card" bindtap="navigateToTool" data-tool="batch">
        <view class="tool-icon">
          <text class="icon">📦</text>
        </view>
        <view class="tool-name">批量处理</view>
        <view class="tool-desc">多图片批量操作</view>
      </view>
    </view>
  </view>

  <view class="footer">
    <view class="footer-text">© 2026 图像工具箱</view>
  </view>
</view>
