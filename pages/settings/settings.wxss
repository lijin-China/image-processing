.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 48rpx;
  background: linear-gradient(180deg, #F0F5FF 0%, #F6F7FB 100%);
  box-sizing: border-box;
}

.header {
  display: flex;
  align-items: center;
  padding: 16rpx 8rpx 32rpx;
}

.headerIcon {
  font-size: 56rpx;
  margin-right: 20rpx;
}

.headerContent {
  flex: 1;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1F2937;
}

.subtitle {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #6B7280;
}

.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(30, 111, 255, 0.08);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.cardHeader {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #F3F4F6;
}

.cardIcon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.cardTitle {
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2937;
}

.settingItem {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.settingItem:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.settingLabel {
  margin-bottom: 16rpx;
}

.labelText {
  font-size: 30rpx;
  color: #1F2937;
  font-weight: 600;
  display: block;
}

.labelDesc {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
  display: block;
}

.seg {
  display: flex;
  background: #F3F4F6;
  border-radius: 16rpx;
  padding: 6rpx;
}

.segItem {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #6B7280;
  transition: all 0.2s ease;
}

.segItem.on {
  background: #FFFFFF;
  color: #1E6FFF;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(30, 111, 255, 0.15);
}

.colorRow {
  display: flex;
  gap: 16rpx;
}

.colorItem {
  flex: 1;
  height: 100rpx;
  border-radius: 16rpx;
  border: 2rpx solid #E5E7EB;
  transition: all 0.2s ease;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 12rpx;
  position: relative;
  overflow: hidden;
}

.colorItem.on {
  border: 3rpx solid #1E6FFF !important;
  box-shadow: 0 0 0 6rpx rgba(30, 111, 255, 0.15);
  transform: scale(1.02);
}

.colorLabel {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.3);
}

.colorItem[style*="background: #FFFFFF"] .colorLabel {
  color: #6B7280;
  text-shadow: none;
}

.dragNumWrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
}

.dragNumInner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 60rpx;
  background: linear-gradient(135deg, #EFF6FF 0%, #DBEAFE 100%);
  border-radius: 20rpx;
  border: 2rpx solid #BFDBFE;
  min-width: 240rpx;
}

.dragNumValue {
  font-size: 56rpx;
  font-weight: 700;
  color: #1E6FFF;
  line-height: 1.2;
}

.dragNumHint {
  font-size: 22rpx;
  color: #60A5FA;
  margin-top: 8rpx;
  font-weight: 500;
}

.tipsCard {
  margin-top: 20rpx;
  background: linear-gradient(135deg, rgba(30, 111, 255, 0.08) 0%, rgba(99, 102, 241, 0.06) 100%);
  border: 2rpx solid rgba(30, 111, 255, 0.15);
  border-radius: 20rpx;
  padding: 24rpx;
}

.tipsHeader {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.tipsIcon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.tipsTitle {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2937;
}

.tipsContent {
  padding-left: 8rpx;
}

.tipsLine {
  display: flex;
  align-items: flex-start;
  margin-top: 12rpx;
}

.tipsDot {
  width: 12rpx;
  height: 12rpx;
  background: #1E6FFF;
  border-radius: 50%;
  margin-right: 12rpx;
  margin-top: 10rpx;
  flex-shrink: 0;
}

.tipsLine text {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
}

.footer {
  text-align: center;
  padding: 40rpx 0 20rpx;
}

.footerText {
  font-size: 24rpx;
  color: #9CA3AF;
}
