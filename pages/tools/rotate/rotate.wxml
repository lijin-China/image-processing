<view class="page">
  <view class="card">
    <view class="cardTitle">选择图片</view>
    <view class="imagePreview" wx:if="{{inputPath}}">
      <image class="previewImage" src="{{inputPath}}" mode="aspectFill" bindtap="preview" data-url="{{inputPath}}" />
      <view class="imageInfo">
        <text class="infoText">已选择图片</text>
        <text class="infoSize" wx:if="{{inputSizeKB}}">{{inputSizeKB}}KB</text>
      </view>
      <view class="changeBtn" bindtap="choose">更换</view>
    </view>
    <button class="primaryBtn" wx:else bindtap="choose">从相册/相机选择</button>
  </view>

  <view class="card" wx:if="{{inputPath}}">
    <view class="cardTitle">旋转设置</view>

    <view class="row">
      <text class="label">旋转角度</text>
      <view class="seg">
        <view class="segItem {{rotate === 0 ? 'on' : ''}}" bindtap="onRotateChange" data-rotate="{{0}}">0°</view>
        <view class="segItem {{rotate === 90 ? 'on' : ''}}" bindtap="onRotateChange" data-rotate="{{90}}">90°</view>
        <view class="segItem {{rotate === 180 ? 'on' : ''}}" bindtap="onRotateChange" data-rotate="{{180}}">180°</view>
        <view class="segItem {{rotate === 270 ? 'on' : ''}}" bindtap="onRotateChange" data-rotate="{{270}}">270°</view>
      </view>
    </view>

    <view class="row">
      <text class="label">翻转</text>
      <view class="seg">
        <view class="segItem {{flip === 'none' ? 'on' : ''}}" bindtap="onFlipChange" data-flip="none">无</view>
        <view class="segItem {{flip === 'horizontal' ? 'on' : ''}}" bindtap="onFlipChange" data-flip="horizontal">水平</view>
        <view class="segItem {{flip === 'vertical' ? 'on' : ''}}" bindtap="onFlipChange" data-flip="vertical">垂直</view>
      </view>
    </view>

    <view class="row">
      <button class="primaryBtn" disabled="{{busy}}" bindtap="run">开始旋转</button>
    </view>
  </view>

  <view class="card" wx:if="{{result}}">
    <view class="cardTitle">结果预览</view>
    <view class="previewGrid">
      <view class="previewItem">
        <text class="previewLabel">原图</text>
        <image class="previewImg" src="{{result.inputPath}}" mode="aspectFill" bindtap="preview" data-url="{{result.inputPath}}" />
        <text class="previewMeta">{{result.inputSizeKB}}KB</text>
      </view>
      <view class="previewItem">
        <text class="previewLabel">处理后</text>
        <image class="previewImg" src="{{result.outputPath}}" mode="aspectFill" bindtap="preview" data-url="{{result.outputPath}}" />
        <text class="previewMeta">{{result.outputSizeKB}}KB</text>
      </view>
    </view>

    <view class="actions">
      <button class="primaryBtn" bindtap="save">保存到相册</button>
      <button class="ghostBtn" bindtap="share">分享</button>
    </view>
  </view>

  <canvas type="2d" id="toolCanvas" class="hiddenCanvas"></canvas>
</view>
