<view class="page">
  <!-- 顶部区域 -->
  <view class="header">
    <view class="headerContent">
      <view class="title">朋友圈</view>
      <view class="subtitle">分享你的精彩瞬间</view>
    </view>
    <button class="publishBtn" bindtap="openPublishModal">
      <text class="publishIcon">+</text>
    </button>
  </view>

  <!-- 动态列表 -->
  <view class="postList" wx:if="{{posts.length}}">
    <view class="postItem" wx:for="{{posts}}" wx:key="_id">
      <!-- 用户信息 -->
      <view class="postHeader">
        <image class="avatar" src="{{item.userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="userInfo">
          <view class="nickName">{{item.userInfo.nickName}}</view>
          <view class="postTime">{{item.formattedTime}}</view>
        </view>
      </view>

      <!-- 图片 -->
      <view class="postImageWrap" bindtap="previewImage" data-url="{{item.imageUrl}}">
        <image class="postImage" src="{{item.imageUrl}}" mode="widthFix" />
      </view>

      <!-- 描述 -->
      <view class="postDesc" wx:if="{{item.description}}">{{item.description}}</view>

      <!-- 互动区域 -->
      <view class="postActions">
        <view class="actionItem {{item.isLiked ? 'liked' : ''}}" bindtap="toggleLike" data-id="{{item._id}}" data-liked="{{item.isLiked}}">
          <text class="actionIcon">{{item.isLiked ? '❤️' : '🤍'}}</text>
          <text class="actionNum">{{item.likeCount || 0}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loadingWrap" wx:if="{{loading}}">
    <view class="loadingSpinner"></view>
    <text class="loadingText">加载中...</text>
  </view>

  <!-- 无更多数据 -->
  <view class="noMore" wx:if="{{!hasMore && posts.length && !loading}}">
    <text>没有更多了</text>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!posts.length && !loading}}">
    <view class="emptyIcon">📷</view>
    <view class="emptyTitle">还没有动态</view>
    <view class="emptySub">点击右上角发布第一条动态吧</view>
    <button class="primaryBtn" bindtap="openPublishModal">发布动态</button>
  </view>
</view>

<!-- 发布弹窗 -->
<view class="modalMask" wx:if="{{showPublishModal}}" bindtap="closePublishModal">
  <view class="modalContent" catchtap="preventClose">
    <view class="modalHeader">
      <view class="modalTitle">发布动态</view>
      <view class="modalClose" catchtap="closePublishModal">×</view>
    </view>

    <!-- 图片选择 -->
    <view class="imagePicker" catchtap="chooseImage">
      <image wx:if="{{publishImage}}" class="previewImg" src="{{publishImage}}" mode="aspectFill" />
      <view wx:else class="placeholder">
        <text class="placeholderIcon">🖼️</text>
        <text class="placeholderText">点击选择图片</text>
      </view>
    </view>

    <!-- 描述输入 -->
    <view class="descInputWrap">
      <textarea
        class="descInput"
        placeholder="说点什么..."
        maxlength="200"
        value="{{publishDesc}}"
        bindinput="onDescInput"
      />
      <view class="charCount">{{publishDesc.length}}/200</view>
    </view>

    <!-- 发布按钮 -->
    <button class="primaryBtn" catchtap="doPublish" disabled="{{uploading}}">
      {{uploading ? '发布中...' : '发布'}}
    </button>
  </view>
</view>